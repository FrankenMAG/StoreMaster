<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StoreMaster</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome (iconos) -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <!-- DataTables -->
    <link href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" rel="stylesheet" />
    <!-- Estilos propios -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- ── NAVBAR ────────────────────────────────────────── -->
    <nav class="navbar navbar-dark bg-dark px-3 fixed-top">
        <a class="navbar-brand fw-bold" href="/">
            <i class="fas fa-store me-2"></i>StoreMaster
        </a>
        <div class="d-flex align-items-center gap-3">
            <span class="text-white-50 small">
                <i class="fas fa-calendar me-1"></i>
                @DateTime.Now.ToString("dd/MM/yyyy")
            </span>
            <a href="#" class="btn btn-sm btn-outline-light">
                <i class="fas fa-user me-1"></i>Usuario
            </a>
        </div>
    </nav>

    <div class="d-flex" style="margin-top: 56px;">

        <!-- ── SIDEBAR ───────────────────────────────────────── -->
        <nav id="sidebar" class="bg-dark text-white p-3 d-flex flex-column"
             style="min-width: 240px; min-height: calc(100vh - 56px);">

            <!-- Inventario -->
            <p class="text-uppercase text-white-50 small mb-1 mt-2">Inventario</p>
            <a href="/Categorias" class="sidebar-link">
                <i class="fas fa-tags me-2"></i>Categorías
            </a>
            <a href="/Productos" class="sidebar-link">
                <i class="fas fa-box me-2"></i>Productos
            </a>
            <a href="/Proveedores" class="sidebar-link">
                <i class="fas fa-truck me-2"></i>Proveedores
            </a>

            <!-- Ventas -->
            <p class="text-uppercase text-white-50 small mb-1 mt-3">Ventas</p>
            <a href="/Ventas" class="sidebar-link">
                <i class="fas fa-cash-register me-2"></i>Punto de Venta
            </a>
            <a href="/Ventas/Historial" class="sidebar-link">
                <i class="fas fa-history me-2"></i>Historial
            </a>

            <!-- Clientes -->
            <p class="text-uppercase text-white-50 small mb-1 mt-3">Clientes</p>
            <a href="/Clientes" class="sidebar-link">
                <i class="fas fa-users me-2"></i>Clientes
            </a>

            <!-- Reportes -->
            <p class="text-uppercase text-white-50 small mb-1 mt-3">Reportes</p>
            <a href="/Reportes" class="sidebar-link">
                <i class="fas fa-chart-bar me-2"></i>Dashboard
            </a>

        </nav>

        <!-- ── CONTENIDO PRINCIPAL ───────────────────────────── -->
        <main class="flex-grow-1 p-4 bg-light">

            <!-- Mensajes de éxito / error (TempData) -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </main>

    </div>

    <!-- ── FOOTER ────────────────────────────────────────── -->
    <footer class="bg-dark text-white-50 text-center py-2 small">
        StoreMaster &copy; @DateTime.Now.Year — Sistema de Gestión
    </footer>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>