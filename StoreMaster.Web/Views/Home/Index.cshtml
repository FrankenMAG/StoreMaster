@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">
        <i class="fas fa-tachometer-alt me-2 text-primary"></i>Dashboard
    </h4>
    <span class="text-muted small">Bienvenido a StoreMaster</span>
</div>

<!-- KPI Cards (placeholder por ahora) -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card p-3">
            <div class="text-muted small">Ventas hoy</div>
            <div class="fs-4 fw-bold text-success">$0.00</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3">
            <div class="text-muted small">Productos</div>
            <div class="fs-4 fw-bold text-primary">0</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3">
            <div class="text-muted small">Clientes</div>
            <div class="fs-4 fw-bold text-info">0</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3">
            <div class="text-muted small">Stock bajo</div>
            <div class="fs-4 fw-bold text-danger">0</div>
        </div>
    </div>
</div>