@model StoreMaster.Web.ViewModels.ProductoViewModel
@{
    ViewData["Title"] = "Editar Producto";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">
        <i class="fas fa-edit me-2 text-primary"></i>Editar Producto
    </h4>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Volver
    </a>
</div>

<div class="card" style="max-width: 700px;">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />

            <div class="row">
                <div class="col-md-8 mb-3">
                    <label asp-for="Nombre" class="form-label fw-semibold"></label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="CodigoBarras" class="form-label fw-semibold"></label>
                    <input asp-for="CodigoBarras" class="form-control" />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label fw-semibold"></label>
                <textarea asp-for="Descripcion" class="form-control" rows="2"></textarea>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="CategoriaId" class="form-label fw-semibold"></label>
                    <select asp-for="CategoriaId" asp-items="Model.Categorias"
                            class="form-select">
                        <option value="">-- Selecciona una categoría --</option>
                    </select>
                    <span asp-validation-for="CategoriaId" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="ProveedorId" class="form-label fw-semibold"></label>
                    <select asp-for="ProveedorId" asp-items="Model.Proveedores"
                            class="form-select">
                        <option value="">-- Selecciona un proveedor --</option>
                    </select>
                    <span asp-validation-for="ProveedorId" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Precio" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="Precio" class="form-control" />
                    </div>
                    <span asp-validation-for="Precio" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="PrecioCompra" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="PrecioCompra" class="form-control" />
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Stock" class="form-label fw-semibold"></label>
                    <input asp-for="Stock" class="form-control" />
                    <span asp-validation-for="Stock" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="StockMinimo" class="form-label fw-semibold"></label>
                    <input asp-for="StockMinimo" class="form-control" />
                    <div class="form-text">Alerta cuando el stock baje de este número</div>
                </div>
            </div>

            <!-- Stock crítico -->
            @if (Model.StockCritico)
            {
                <div class="alert alert-warning py-2 mb-3">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <strong>Stock crítico.</strong> El stock actual está por debajo del mínimo.
                </div>
            }

            <div class="mb-4">
                <div class="form-check form-switch">
                    <input asp-for="Activo" class="form-check-input" />
                    <label asp-for="Activo" class="form-check-label">Producto activo</label>
                </div>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger py-2 mb-3">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div><i class="fas fa-exclamation-circle me-1"></i>@error.ErrorMessage</div>
                    }
                </div>
            }
            <div class="mb-3">
                <label asp-for="ImagenFile" class="form-label fw-semibold"></label>

                @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                {
                    <div class="mb-2">
                        <img src="~/images/productos/@Model.ImagenUrl"
                             alt="Imagen actual"
                             class="rounded"
                             style="width: 100px; height: 100px; object-fit: cover;" />
                        <div class="text-muted small mt-1">Imagen actual</div>
                    </div>
                }

                <input asp-for="ImagenFile" class="form-control" type="file"
                       accept=".jpg,.jpeg,.png,.webp" />
                <input asp-for="ImagenUrl" type="hidden" />
                <div class="form-text">Deja vacío para mantener la imagen actual</div>
                <span asp-validation-for="ImagenFile" class="text-danger small"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="fas fa-save me-2"></i>Guardar Cambios
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancelar</a>
            </div>
        </form>
    </div>
</div>