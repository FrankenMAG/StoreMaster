@model IEnumerable<StoreMaster.Web.ViewModels.ProductoViewModel>
@{
    ViewData["Title"] = "Productos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">
        <i class="fas fa-box me-2 text-primary"></i>Productos
    </h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Nuevo Producto
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0" id="tablaProductos">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Categoría</th>
                    <th>Proveedor</th>
                    <th class="text-end">Precio</th>
                    <th class="text-center">Stock</th>
                    <th>Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var producto in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <img src="@(string.IsNullOrEmpty(producto.ImagenUrl)
                                                         ? "/images/placeholder.png"
                                                         : $"/images/productos/{producto.ImagenUrl}")"
                                     alt="@producto.Nombre"
                                     style="width: 40px; height: 40px; object-fit: cover; border-radius: 6px;" />
                                <div>
                                    <div class="fw-semibold">@producto.Nombre</div>
                                    @if (!string.IsNullOrEmpty(producto.CodigoBarras))
                                    {
                                        <div class="text-muted small">
                                            <i class="fas fa-barcode me-1"></i>@producto.CodigoBarras
                                        </div>
                                    }
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="badge bg-primary bg-opacity-10 text-primary">
                                @producto.CategoriaNombre
                            </span>
                        </td>
                        <td class="text-muted">@producto.ProveedorNombre</td>
                        <td class="text-end fw-semibold">
                            $@producto.Precio.ToString("N2")
                        </td>
                        <td class="text-center">
                            @if (producto.StockCritico)
                            {
                                <span class="badge bg-danger">
                                    <i class="fas fa-exclamation-triangle me-1"></i>
                                    @producto.Stock
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-success">@producto.Stock</span>
                            }
                        </td>
                        <td>
                            @if (producto.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactivo</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@producto.Id"
                               class="btn btn-sm btn-outline-primary me-1">
                                <i class="fas fa-edit"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@producto.Id"
                                  method="post" class="d-inline"
                                  onsubmit="return confirm('¿Eliminar producto @producto.Nombre?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                
            </tbody>
        </table>
    </div>
</div>
@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaProductos').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json',
                    emptyTable: 'No hay productos registrados'
                },
                pageLength: 10,
                autoWidth: false,
                ordering: true,
                columnDefs: [
                    { orderable: false, targets: '_all' }
                ],
                "bStateSave": false
            });
        });
    </script>
}