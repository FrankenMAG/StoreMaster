@model StoreMaster.Web.ViewModels.ReportesViewModel
@{
    ViewData["Title"] = "Reportes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">
        <i class="fas fa-chart-bar me-2 text-primary"></i>Reportes
    </h4>
</div>

<!-- ── Filtro de fechas ──────────────────────────────── -->
<div class="card mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-semibold">Desde</label>
                <input type="date" name="desde" class="form-control"
                       value="@Model.Desde.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-4">
                <label class="form-label fw-semibold">Hasta</label>
                <input type="date" name="hasta" class="form-control"
                       value="@Model.Hasta.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-filter me-2"></i>Filtrar
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ── KPIs del rango ────────────────────────────────── -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card p-3 border-start border-success border-4">
            <div class="text-muted small">Total ventas en el período</div>
            <div class="fs-4 fw-bold text-success">
                $@Model.TotalRango.ToString("N2")
            </div>
            <div class="text-muted small">
                @Model.CountRango transacción(es)
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-3 border-start border-primary border-4">
            <div class="text-muted small">Valor total inventario</div>
            <div class="fs-4 fw-bold text-primary">
                $@Model.ValorTotalInventario.ToString("N2")
            </div>
            <div class="text-muted small">
                @Model.Inventario.Count producto(s)
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-3 border-start border-info border-4">
            <div class="text-muted small">Promedio por venta</div>
            <div class="fs-4 fw-bold text-info">
                $@(Model.CountRango > 0
                                ? (Model.TotalRango / Model.CountRango).ToString("N2")
                                : "0.00")
            </div>
            <div class="text-muted small">en el período</div>
        </div>
    </div>
</div>

<!-- ── Ventas por rango ──────────────────────────────── -->
<div class="card mb-4">
    <div class="card-header bg-dark text-white">
        <i class="fas fa-calendar me-2"></i>
        Ventas del @Model.Desde.ToString("dd/MM/yyyy") al @Model.Hasta.ToString("dd/MM/yyyy")
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0" id="tablaVentasRango">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Fecha</th>
                    <th>Cliente</th>
                    <th class="text-center">Items</th>
                    <th class="text-end">Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var venta in Model.VentasPorRango)
                {
                    <tr>
                        <td>
                            <a asp-controller="Ventas" asp-action="Detalle"
                               asp-route-id="@venta.Id" class="fw-semibold">
                                #@venta.Id
                            </a>
                        </td>
                        <td>@venta.Fecha.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@(venta.Cliente?.NombreCompleto ?? "Cliente General")</td>
                        <td class="text-center">@venta.Detalles.Count</td>
                        <td class="text-end fw-bold text-success">
                            $@venta.Total.ToString("N2")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- ── Inventario valorizado ─────────────────────────── -->
<div class="card mb-4">
    <div class="card-header bg-dark text-white">
        <i class="fas fa-boxes me-2"></i>Inventario Valorizado
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0" id="tablaInventario">
            <thead>
                <tr>
                    <th>Producto</th>
                    <th>Categoría</th>
                    <th class="text-center">Stock</th>
                    <th class="text-end">Precio</th>
                    <th class="text-end">Valor Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var producto in Model.Inventario)
                {
                    <tr>
                        <td class="fw-semibold">@producto.Nombre</td>
                        <td class="text-muted">@producto.Categoria?.Nombre</td>
                        <td class="text-center">
                            @if (producto.Stock <= producto.StockMinimo)
                            {
                                <span class="badge bg-danger">@producto.Stock</span>
                            }
                            else
                            {
                                <span class="badge bg-success">@producto.Stock</span>
                            }
                        </td>
                        <td class="text-end">$@producto.Precio.ToString("N2")</td>
                        <td class="text-end fw-bold">
                            $@((producto.Stock * producto.Precio).ToString("N2"))
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="table-dark">
                    <td colspan="4" class="fw-bold">Total Inventario</td>
                    <td class="text-end fw-bold">
                        $@Model.ValorTotalInventario.ToString("N2")
                    </td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

<!-- ── Ventas por cliente ─────────────────────────────── -->
<div class="card mb-4">
    <div class="card-header bg-dark text-white">
        <i class="fas fa-users me-2"></i>Ventas por Cliente
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0" id="tablaClientes">
            <thead>
                <tr>
                    <th>Cliente</th>
                    <th class="text-center">Transacciones</th>
                    <th class="text-end">Total Comprado</th>
                    <th class="text-end">Promedio</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var (cliente, total, transacciones) in Model.VentasPorCliente)
                {
                    <tr>
                        <td class="fw-semibold">@cliente</td>
                        <td class="text-center">@transacciones</td>
                        <td class="text-end fw-bold text-success">
                            $@total.ToString("N2")
                        </td>
                        <td class="text-end text-muted">
                            $@((total / transacciones).ToString("N2"))
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaVentasRango').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json',
                    emptyTable: 'No hay ventas en este período'
                },
                pageLength: 10,
                autoWidth: false,
                order: [[0, 'desc']],
                columnDefs: [{ orderable: false, targets: [] }]
            });

            $('#tablaInventario').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json'
                },
                pageLength: 10,
                autoWidth: false,
                order: [[4, 'desc']]
            });

            $('#tablaClientes').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json',
                    emptyTable: 'No hay datos de clientes'
                },
                pageLength: 10,
                autoWidth: false,
                order: [[2, 'desc']]
            });
        });
    </script>
}