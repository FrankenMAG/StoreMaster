@model StoreMaster.Web.ViewModels.CategoriaViewModel
@{
    ViewData["Title"] = "Nueva Categoría";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">
        <i class="fas fa-plus me-2 text-primary"></i>Nueva Categoría
    </h4>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Volver
    </a>
</div>

<div class="card" style="max-width: 600px;">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label fw-semibold"></label>
                <input asp-for="Nombre" class="form-control" placeholder="Ej: Electrónica" />
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label fw-semibold"></label>
                <textarea asp-for="Descripcion" class="form-control" rows="3"
                          placeholder="Descripción opcional"></textarea>
                <span asp-validation-for="Descripcion" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <div class="form-check form-switch">
                    <input asp-for="Activa" class="form-check-input" />
                    <label asp-for="Activa" class="form-check-label">Categoría activa</label>
                </div>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger py-2 mb-3">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div><i class="fas fa-exclamation-circle me-1"></i>@error.ErrorMessage</div>
                    }
                </div>
            }

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="fas fa-save me-2"></i>Guardar
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>