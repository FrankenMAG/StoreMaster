@model IEnumerable<StoreMaster.Web.ViewModels.CategoriaViewModel>
@{
    ViewData["Title"] = "Categorías";
}

<!-- Encabezado -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">
        <i class="fas fa-tags me-2 text-primary"></i>Categorías
    </h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Nueva Categoría
    </a>
</div>

<!-- Tabla -->
<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th>Estado</th>
                    <th>Creada</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var categoria in Model)
                {
                    <tr>
                        <td class="fw-semibold">@categoria.Nombre</td>
                        <td class="text-muted">@(categoria.Descripcion ?? "—")</td>
                        <td>
                            @if (categoria.Activa)
                            {
                                <span class="badge bg-success">Activa</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactiva</span>
                            }
                        </td>
                        <td class="text-muted small">
                            @categoria.CreadoEn.ToString("dd/MM/yyyy")
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@categoria.Id"
                               class="btn btn-sm btn-outline-primary me-1">
                                <i class="fas fa-edit"></i>
                            </a>
                            @if (categoria.Id != 1)
                            {
                                <form asp-action="Delete" asp-route-id="@categoria.Id"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('¿Eliminar categoría @categoria.Nombre?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            <i class="fas fa-inbox fa-2x mb-2 d-block"></i>
                            No hay categorías registradas
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>