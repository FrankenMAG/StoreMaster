@model IEnumerable<StoreMaster.Core.Entities.Venta>
@{
    ViewData["Title"] = "Historial de Ventas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">
        <i class="fas fa-history me-2 text-primary"></i>Historial de Ventas
    </h4>
    <a asp-action="PuntoDeVenta" class="btn btn-primary">
        <i class="fas fa-cash-register me-2"></i>Nueva Venta
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0" id="tablaVentas">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Fecha</th>
                    <th>Cliente</th>
                    <th>Productos</th>
                    <th class="text-end">Total</th>
                    <th>Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var venta in Model)
                {
                    <tr>
                        <td class="fw-semibold">#@venta.Id</td>
                        <td>@venta.Fecha.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@(venta.Cliente?.NombreCompleto ?? "Cliente General")</td>
                        <td class="text-muted small">@venta.Detalles.Count item(s)</td>
                        <td class="text-end fw-bold text-success">
                            $@venta.Total.ToString("N2")
                        </td>
                        <td>
                            @switch (venta.Estado)
                            {
                                case StoreMaster.Core.Entities.EstadoVenta.Completada:
                                    <span class="badge bg-success">Completada</span>
                                    break;
                                case StoreMaster.Core.Entities.EstadoVenta.Cancelada:
                                    <span class="badge bg-danger">Cancelada</span>
                                    break;
                                case StoreMaster.Core.Entities.EstadoVenta.Pendiente:
                                    <span class="badge bg-warning">Pendiente</span>
                                    break;
                                default:
                                    <span class="badge bg-secondary">@venta.Estado</span>
                                    break;
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Detalle" asp-route-id="@venta.Id"
                               class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaVentas').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json',
                    emptyTable: 'No hay ventas registradas'
                },
                pageLength: 15,
                autoWidth: false,
                order: [[0, 'desc']],
                columnDefs: [
                    { orderable: false, targets: [6] }
                ]
            });
        });
    </script>
}