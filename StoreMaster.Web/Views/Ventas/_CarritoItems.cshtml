@model StoreMaster.Core.Entities.Carrito

@if (!Model.Items.Any())
{
    <div class="text-center text-muted py-5">
        <i class="fas fa-shopping-cart fa-3x mb-3 d-block opacity-25"></i>
        <p>El carrito está vacío</p>
    </div>
}
else
{
    <input type="hidden" id="carritoData"
           value='{"totalItems":@Model.TotalItems,"total":"@Model.Total.ToString("N2")"}' />

    @foreach (var item in Model.Items)
    {
        <div class="d-flex align-items-center gap-2 p-2 border-bottom" id="item_@item.ProductoId">
            <img src="@(string.IsNullOrEmpty(item.ImagenUrl) ? "/images/placeholder.png" : $"/images/productos/{item.ImagenUrl}")"
                 style="width:40px;height:40px;object-fit:cover;border-radius:6px;" />
            <div class="flex-grow-1">
                <div class="fw-semibold small">@item.Nombre</div>
                <div class="text-muted small">$@item.PrecioUnitario.ToString("N2") c/u</div>
            </div>
            <div class="d-flex align-items-center gap-1">
                <input type="number" class="form-control form-control-sm text-center"
                       style="width:60px;" value="@item.Cantidad" min="1"
                       onchange="actualizarCantidad(@item.ProductoId, this.value)" />
                <button class="btn btn-sm btn-outline-danger"
                        onclick="eliminarDelCarrito(@item.ProductoId)">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="text-end" style="min-width:70px;">
                <span class="fw-bold text-success small">$@item.Subtotal.ToString("N2")</span>
            </div>
        </div>
    }
}