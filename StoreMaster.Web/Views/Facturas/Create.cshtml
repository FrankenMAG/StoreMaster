@model StoreMaster.Web.ViewModels.CrearFacturaViewModel
@{
    ViewData["Title"] = "Generar Factura";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">
        <i class="fas fa-file-invoice me-2 text-primary"></i>Generar Factura
    </h4>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Volver
    </a>
</div>

<div class="card" style="max-width: 500px;">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="VentaId" type="hidden" />

            <div class="mb-3">
                <label class="form-label fw-semibold">Venta a facturar</label>
                <input type="text" class="form-control"
                       value="Venta #@Model.VentaId" readonly />
            </div>

            <div class="mb-4">
                <label asp-for="Serie" class="form-label fw-semibold"></label>
                <input asp-for="Serie" class="form-control"
                       placeholder="A" maxlength="3" />
                <div class="form-text">
                    letra que identifica la serie de facturas (A, B, C...)
                </div>
                <span asp-validation-for="Serie" class="text-danger small"></span>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger py-2 mb-3">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>
                            <i class="fas fa-exclamation-circle me-1"></i>
                            @error.ErrorMessage
                        </div>
                    }
                </div>
            }

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="fas fa-file-invoice me-2"></i>Generar Factura
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>