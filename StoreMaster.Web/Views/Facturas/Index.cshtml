@model IEnumerable<StoreMaster.Web.ViewModels.FacturaViewModel>
@{
    ViewData["Title"] = "Facturas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">
        <i class="fas fa-file-invoice me-2 text-primary"></i>Facturas
    </h4>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0" id="tablaFacturas">
            <thead>
                <tr>
                    <th>Folio Factura</th>
                    <th>Fecha Emisión</th>
                    <th>RFC</th>
                    <th>Nombre Cliente</th>
                    <th class="text-end">Total</th>
                    <th>Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var factura in Model)
                {
                    <tr>
                        <td class="fw-semibold">#@factura.FolioCompleto</td>
                        <td>@factura.FechaEmision.ToLocalTime().ToString("dd/MM/yyyy")</td>
                        <td>@(factura.RFCReceptor)</td>
                        <td>@(factura.NombreReceptor??"Cliente General")</td>
                        <td>@factura.Total.ToString("N2")</td>
                        <td>@switch (factura.Estado)
                            {
                                case StoreMaster.Core.Entities.EstadoFactura.Vigente:
                                    <span class="badge bg-success">Vigente</span>
                                    break;
                                case StoreMaster.Core.Entities.EstadoFactura.Cancelada:
                                    <span class="badge bg-danger">Cancelada</span>
                                    break;
                                default:
                                    <span class="badge bg-secondary">@factura.Estado</span>
                                    break;
                            }

                        </td>
                        <td class="text-center">
                            <a asp-action="Detalle" asp-route-id="@factura.Id"
                               class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tablaFacturas').DataTable({
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/1.13.7/i18n/es-MX.json',
                    emptyTable: 'No hay facturas registradas'
                },
                pageLength: 10,
                autoWidth: false,
                order: [[0, 'desc']]
            });
        });
    </script>
}