@model StoreMaster.Web.ViewModels.ClienteViewModel
@{
    ViewData["Title"] = "Editar Cliente";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">
        <i class="fas fa-edit me-2 text-primary"></i>Editar Cliente
    </h4>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="fas fa-arrow-left me-2"></i>Volver
    </a>
</div>

<div class="card" style="max-width: 600px;">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Nombre" class="form-label fw-semibold"></label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Apellido" class="form-label fw-semibold"></label>
                    <input asp-for="Apellido" class="form-control" />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Telefono" class="form-label fw-semibold"></label>
                    <input asp-for="Telefono" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Email" class="form-label fw-semibold"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Direccion" class="form-label fw-semibold"></label>
                <textarea asp-for="Direccion" class="form-control" rows="2"></textarea>
            </div>
            <div class="mb-3">
                <label asp-for="RFC" class="form-label fw-semibold"></label>
                <textarea asp-for="RFC" class="form-control" rows="2"></textarea>
            </div>
            <div class="mb-3">
                <label asp-for="RazonSocial" class="form-label fw-semibold"></label>
                <textarea asp-for="RazonSocial" class="form-control" rows="2"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="RegimenFIscal" class="form-label fw-semibold"></label>
                <textarea asp-for="RegimenFIscal" class="form-control" rows="2"></textarea>
            </div>
            <div class="mb-3">
                <label asp-for="CodigoPostalFiscal" class="form-label fw-semibold"></label>
                <textarea asp-for="CodigoPostalFiscal" class="form-control" rows="2"></textarea>
            </div>
            <div class="mb-4">
                <div class="form-check form-switch">
                    <input asp-for="Activo" class="form-check-input" />
                    <label asp-for="Activo" class="form-check-label">Cliente activo</label>
                </div>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger py-2 mb-3">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div><i class="fas fa-exclamation-circle me-1"></i>@error.ErrorMessage</div>
                    }
                </div>
            }

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="fas fa-save me-2"></i>Guardar Cambios
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancelar</a>
            </div>
        </form>
    </div>
</div>